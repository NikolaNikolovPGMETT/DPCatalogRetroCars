@{
    ViewData["Title"] = "Контакти";
}
<div class="contacts-page">
    <h1 class="mb-3">Контакти</h1>
    <p class="text-muted mb-4">Свържи се с екипа на OldSchoolRides или ни посети на място.</p>

    <div class="card shadow-sm border-0 contacts-card">
        <div class="card-body p-4">
            <div class="row g-4 align-items-stretch">
                <div class="col-lg-5">
                    <h2 class="h5 mb-3">Екипът на OldSchoolRides</h2>
                    <ul class="list-unstyled contacts-list mb-0">
                        <li><strong>Email:</strong> support@oldschoolrides.local</li>
                        <li><strong>Телефон:</strong> +359 700 12 345</li>
                        <li><strong>Адрес:</strong> Шумен, България</li>
                        <li><strong>Работно време:</strong> Понеделник - Петък, 09:00 - 18:00</li>
                    </ul>
                </div>
                <div class="col-lg-7">
                    <div class="map-wrapper" aria-label="Карта с локацията на OldSchoolRides">
                        <iframe title="Карта на OldSchoolRides в Шумен"
                                src="https://www.google.com/maps?q=Shumen%2C+Bulgaria&z=13&output=embed"
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
